制"}, {"type": "text", "value": "第四章　论货币的起源和用途"}, {"type": "text", "value": "第五章　论商品的真实价格与名义价格或其劳动价格与货币价格"}, {"type": "text", "value": "第六章　论商品价格的组成部分"}, {"type": "text", "value": "第七章　论商品的自然价格与市场价格"}, {"type": "text", "value": "第八章　论劳动工资"}, {"type": "text", "value": "第九章　论资本利润"}, {"type": "text", "value": "第十章　论工资与利润随劳动与资本用途的不同而不同"}, {"type": "text", "value": "第十一章　论地租"}, {"type": "text", "value": "第二篇　论资财的性质及其蓄积和用途"}, {"type": "text", "value": "导言"}, {"type": "text", "value": "第一章　论资财的分类"}, {"type": "text", "value": "第二章　论作为社会总资财的一个特殊部门或作为维持国民资本的费用的货币"}, {"type": "text", "value": "第三章　论资本积累并论生产性和非生产性劳动"}, {"type": "text", "value": "第四章　论贷出取息的资财"}, {"type": "text", "value": "第五章　论资本的各种用途"}, {"type": "text", "value": "第三篇　论不同国家的财富的不同发展"}, {"type": "text", "value": "第一章　论财富的自然发展"}, {"type": "text", "value": "第二章　论罗马帝国崩溃后农业在欧洲旧状态下所受到的阻抑"}, {"type": "text", "value": "第三章　论罗马帝国崩溃后都市的勃兴与进步"}, {"type": "text", "value": "第四章　都市商业对农村改良的贡献"}, {"type": "text", "value": "第四篇　政治经济学体系"}, {"type": "text", "value": "导言"}, {"type": "text", "value": "第一章　商业主义和重商主义原理"}, {"type": "text", "value": "第二章　论限制能在本国生产的外国货物的进口"}, {"type": "text", "value": "第三章　论对其贸易差额被认为于我不利的那些国家的几乎所有货物进口施加的特别限制"}, {"type": "text", "value": "第四章　论退税"}, {"type": "text", "value": "第五章　论奖励金"}, {"type": "text", "value": "第六章　论通商条约"}, {"type": "text", "value": "第七章　论殖民地"}, {"type": "text", "value": "第八章　关于重商主义的结论"}, {"type": "text", "value": "第九章　论重农主义即政治经济学中把土地生产物看作各国收入及财富的唯一"}, {"type": "text", "value": "第五篇　论君主和国家的税收"}, {"type": "text", "value": "第一章　论君主或国家的支出"}, {"type": "text", "value": "第二章　论社会一般收入或国库收入的源泉"}, {"type": "text", "value": "第三章　论公债"}, {"type": "text", "value": "返回总目录"}]}