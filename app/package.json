{
  "name": "deepphilosophy",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-packager . DeepPhilosophy --platform=win32 --arch=x64 --out=out --overwrite && electron-builder --win --prepackaged out/DeepPhilosophy-win32-x64",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.txdsyl.deepphilosophy",
    "productName": "DeepPhilosophy",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "public/favicon.png"
    }
  },
  "dependencies": {
    "epubjs": "^0.3.93",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.2",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
